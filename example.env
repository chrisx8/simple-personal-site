############################################################################
# Rename this file to '.env' and edit settings accordingly
# All fields are REQUIRED, unless otherwise noted
############################################################################

## Allowed hostnames
# Separate URLs by commas. NO SPACE
ALLOWED_HOSTS=example.com,www.example.com,localhost

## SSL/TLS
# Server uses SSL/TLS (True/False). Requires reverse proxy for SSL/TLS.
SITE_SSL=True

## Database credentials
# Supported database types: postgresql, mysql, sqlite3
DB_TYPE=sqlite3
## Database name (database name for mysql/postgresql, relative path for sqlite3)
DB_NAME=site.db
## Database hostname/port
DB_HOST=
DB_PORT=
## Database username/password
DB_USERNAME=
DB_PASSWORD=

## URL to the Admin Panel.
# Change the default for improved security. Leave blank to disable Admin Panel.
# Include a trailing slash, but don't include preceding slash
ADMIN_URL=admin/

## [Optional] Email settings. Leave blank to disable email.
## SMTP server hostname and port
EMAIL_HOST=
EMAIL_PORT=
## SMTP username/password
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
## Use SSL/TLS (True/False). Do not enable both SSL and TLS.
EMAIL_USE_TLS=
EMAIL_USE_SSL=

## [Optional] Nonce for CSP.
# If you're not using CSP with nonce, leave this blank.
NONCE=

## [Optional] FULL URL to status page
# Shown in footer of error pages. Use FULL URL (include http:// or https://).
# If you don't have a status page, leave this blank.
STATUS_PAGE_URL=

## [Optional] Single Sign-On using OpenID Connect with
# Enable OpenID Connect (True/False). External identity provider required.
USE_OIDC=False
# Client ID and Secret
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
# Authorization Endpoint
OIDC_OP_AUTHORIZATION_ENDPOINT=
# Token Endpoint
OIDC_OP_TOKEN_ENDPOINT=
# Userinfo Endpoint
OIDC_OP_USER_ENDPOINT=
# Signing algorithm for ID tokens
OIDC_RP_SIGN_ALGO=
# JWKS URL (for RS256/RS384/RS512)
OIDC_OP_JWKS_ENDPOINT=
